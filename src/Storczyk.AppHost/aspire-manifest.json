{
  "resources": {
    "pg": {
      "type": "container.v0",
      "connectionString": "Host={pg.bindings.tcp.host};Port={pg.bindings.tcp.port};Username=postgres;Password={pg-password.value}",
      "image": "docker.io/library/postgres:17.6",
      "env": {
        "POSTGRES_HOST_AUTH_METHOD": "scram-sha-256",
        "POSTGRES_INITDB_ARGS": "--auth-host=scram-sha-256 --auth-local=scram-sha-256",
        "POSTGRES_USER": "postgres",
        "POSTGRES_PASSWORD": "{pg-password.value}"
      },
      "bindings": {
        "tcp": {
          "scheme": "tcp",
          "protocol": "tcp",
          "transport": "tcp",
          "targetPort": 5432
        }
      }
    },
    "prodpol": {
      "type": "value.v0",
      "connectionString": "{pg.connectionString};Database=prodpol"
    },
    "StorczykProdpol": {
      "type": "project.v0",
      "path": "../Storczyk.Prodpol/Storczyk.Prodpol.fsproj",
      "env": {
        "OTEL_DOTNET_EXPERIMENTAL_OTLP_RETRY": "in_memory",
        "ASPNETCORE_FORWARDEDHEADERS_ENABLED": "true",
        "HTTP_PORTS": "{StorczykProdpol.bindings.http.targetPort}",
        "ConnectionStrings__postgresdb": "{prodpol.connectionString}",
        "POSTGRESDB_HOST": "{pg.bindings.tcp.host}",
        "POSTGRESDB_PORT": "{pg.bindings.tcp.port}",
        "POSTGRESDB_USERNAME": "postgres",
        "POSTGRESDB_PASSWORD": "{pg-password.value}",
        "POSTGRESDB_URI": "postgresql://postgres:{pg-password-uri-encoded.value}@{pg.bindings.tcp.host}:{pg.bindings.tcp.port}/prodpol",
        "POSTGRESDB_JDBCCONNECTIONSTRING": "jdbc:postgresql://{pg.bindings.tcp.host}:{pg.bindings.tcp.port}/prodpol",
        "POSTGRESDB_DATABASENAME": "prodpol"
      },
      "bindings": {
        "http": {
          "scheme": "http",
          "protocol": "tcp",
          "transport": "http",
          "port": 2138
        },
        "https": {
          "scheme": "https",
          "protocol": "tcp",
          "transport": "http",
          "port": 2139
        }
      }
    },
    "StorczykFrontend": {
      "type": "executable.v0",
      "workingDirectory": "../Storczyk.Frontend",
      "command": "npm",
      "args": [
        "run",
        "dev",
        "--",
        "--port",
        "{StorczykFrontend.bindings.http.targetPort}"
      ],
      "env": {
        "NODE_ENV": "development",
        "VITE_PORT": "{StorczykFrontend.bindings.http.targetPort}",
        "STORCZYKPRODPOL_HTTP": "{StorczykProdpol.bindings.http.url}",
        "services__StorczykProdpol__http__0": "{StorczykProdpol.bindings.http.url}",
        "STORCZYKPRODPOL_HTTPS": "{StorczykProdpol.bindings.https.url}",
        "services__StorczykProdpol__https__0": "{StorczykProdpol.bindings.https.url}",
        "BROWSER": "none",
        "VITE_API_URL": "{StorczykProdpol.bindings.http.url}"
      },
      "bindings": {
        "http": {
          "scheme": "http",
          "protocol": "tcp",
          "transport": "http",
          "targetPort": 8000,
          "external": true
        }
      }
    },
    "StorczykWorker": {
      "type": "project.v0",
      "path": "../Storczyk.Worker/Storczyk.Worker.fsproj",
      "env": {
        "OTEL_DOTNET_EXPERIMENTAL_OTLP_RETRY": "in_memory",
        "ConnectionStrings__postgresdb": "{prodpol.connectionString}",
        "POSTGRESDB_HOST": "{pg.bindings.tcp.host}",
        "POSTGRESDB_PORT": "{pg.bindings.tcp.port}",
        "POSTGRESDB_USERNAME": "postgres",
        "POSTGRESDB_PASSWORD": "{pg-password.value}",
        "POSTGRESDB_URI": "postgresql://postgres:{pg-password-uri-encoded.value}@{pg.bindings.tcp.host}:{pg.bindings.tcp.port}/prodpol",
        "POSTGRESDB_JDBCCONNECTIONSTRING": "jdbc:postgresql://{pg.bindings.tcp.host}:{pg.bindings.tcp.port}/prodpol",
        "POSTGRESDB_DATABASENAME": "prodpol"
      }
    },
    "pg-password": {
      "type": "parameter.v0",
      "value": "{pg-password.inputs.value}",
      "inputs": {
        "value": {
          "type": "string",
          "secret": true,
          "default": {
            "generate": {
              "minLength": 22
            }
          }
        }
      }
    },
    "pg-password-uri-encoded": {
      "type": "annotated.string",
      "value": "{pg-password.value}",
      "filter": "uri"
    }
  }
}